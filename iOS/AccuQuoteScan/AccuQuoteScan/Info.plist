<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en-GB</string>
	<key>CFBundleDisplayName</key>
	<string>AccuQuote</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.accuquote.scan.asset-download</string>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>processing</string>
	</array>
	<key>NSCameraUsageDescription</key>
	<string>AccuQuote Scan uses the camera to measure room dimensions using LiDAR, AI depth, or AR plane detection.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>AccuQuote uses the microphone so you can describe the job by voice — speak naturally and we'll build your quote.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>AccuQuote transcribes your voice description of the job to generate an accurate quote.</string>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>UILaunchScreen</key>
	<dict/>
	<!-- App Store: no proprietary encryption used -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>

	<!-- App Store: privacy manifest keys -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>AccuQuote uses your location to suggest the nearest trade supplier branch for your materials order.</string>

	<key>NSPhotoLibraryUsageDescription</key>
	<string>AccuQuote can save your PDF quote to Photos so you can share it easily.</string>

	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>AccuQuote saves generated quote PDFs to your photo library.</string>

	<!-- App Store Connect: minimum iOS 16, LiDAR optional (not required — app falls back gracefully) -->
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
		<string>arkit</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<!-- Deep link: accuquote://scan launches this app from AccuQuote web -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.accuquote.scan</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>accuquote</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
